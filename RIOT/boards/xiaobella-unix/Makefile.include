UF2_SOFTDEV ?= SD730

CFLAGS+=-DBOARD_SEEEDSTUDIO_XIAO_NRF52840_SENSE

CFLAGS+=-DST77XX_PARAM_CS=GPIO_PIN\(0,4\)      # /**< Chip Select pin */
CFLAGS+=-DST77XX_PARAM_DCX=GPIO_PIN\(0,29\)    #/**< DCX pin */
CFLAGS+=-DST77XX_PARAM_RST=GPIO_PIN\(0,28\)
CFLAGS+=-DST77XX_PARAM_SPI_CLK=SPI_CLK_5MHZ
CFLAGS+=-DST77XX_PARAM_RGB=1
CFLAGS+=-DST77XX_PARAM_NUM_LINES=160
CFLAGS+=-DST77XX_PARAM_RGB_CHANNELS=128

PROGRAMMER=uf2conv

ROM_OFFSET = 0x27000
ROM_LEN    = 0x59000

